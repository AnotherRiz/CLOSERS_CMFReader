## Ignore Visual Studio temporary files, build outputs, and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/xamarin)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Ob]j/
[Log]s/
[Ff]xCop/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# Detailed results directory
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
_backup/

# StyleCop history cache
stylecop.cache

