*.db-wal

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Application Insights config file
ApplicationInsights.config

# RReSharper is a dirty tool
_ReSharper*/
*.[Re]Sharper
*.DotSettings.user

# JustRecompile
JustDecompileAndroid/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
Express/

# DocProject is a documentation generator
DocProject/build/
DocProject/Help/html/
DocProject/Help/htmlhelp/

# ClickOnce directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Local publish folder
bin/AppDev/?*

# Editor Guidelines layout file
.guidelines

# SQLite database file
*.db
*.db3

# TeamCity build micro-repo
.teamcity/

# DotCover coverage results parent folder
dotCover-workspace/

# Rider IDE
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Local History for Visual Studio Code
.history/

# Windows image analyses cache
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# MacOS files
.DS_Store
.AppleDouble
.LSOverride

# Issue documentation / planning
issue.md
planning.md